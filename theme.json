{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1400px"
        },
        "typography": {
            "fontSizes": [
                {
                    "name": "Small",
                    "slug": "small",
                    "size": "12px"
                },
                {
                    "name": "Normal",
                    "slug": "normal",
                    "size": "16px"
                },
                {
                    "name": "Large",
                    "slug": "large",
                    "size": "20px"
                }
            ]
        },
        "color": {
            "palette": [
                {
                    "name": "Primary",
                    "slug": "primary",
                    "color": "#1e73be"
                },
                {
                    "name": "Secondary",
                    "slug": "secondary", 
                    "color": "#666666"
                }
            ]
        },
        "custom": {
            "textDomain": "staynalive"
        }
    },
    "styles": {
        "blocks": {
            "core/paragraph": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--normal)"
                }
            }
        }
    },
    "customTemplates": [
        {
            "name": "single",
            "title": "Single Post",
            "postTypes": ["post"]
        },
        {
            "name": "archive",
            "title": "Archive",
            "postTypes": ["post"]
        },
        {
            "name": "404",
            "title": "404",
            "postTypes": ["page"]
        },
        {
            "name": "link-bio",
            "title": "Link in Bio",
            "postTypes": ["page"]
        }
    ],
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ]
}
