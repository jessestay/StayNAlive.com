{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1400px"
        }
    },
    "customTemplates": [
        {
            "name": "single",
            "title": "Single Post",
            "postTypes": ["post"]
        },
        {
            "name": "archive",
            "title": "Archive",
            "postTypes": ["post"]
        },
        {
            "name": "404",
            "title": "404",
            "postTypes": ["page"]
        },
        {
            "name": "link-bio",
            "title": "Link in Bio",
            "postTypes": ["page"]
        }
    ],
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ]
}
