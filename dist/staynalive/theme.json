{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "primary",
                    "color": "#1e73be",
                    "name": "Primary"
                },
                {
                    "slug": "secondary",
                    "color": "#666666",
                    "name": "Secondary Gray"
                },
                {
                    "slug": "dark",
                    "color": "#333333",
                    "name": "Dark Gray"
                },
                {
                    "slug": "light",
                    "color": "#f5f5f5",
                    "name": "Light Gray"
                },
                {
                    "slug": "white",
                    "color": "#ffffff",
                    "name": "White"
                }
            ],
            "gradients": [],
            "duotone": []
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "Open Sans, sans-serif",
                    "slug": "primary",
                    "name": "Primary"
                },
                {
                    "fontFamily": "Montserrat, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif",
                    "slug": "heading",
                    "name": "Heading Font"
                }
            ],
            "fontSizes": [
                {
                    "slug": "small",
                    "size": "14px",
                    "name": "Small"
                },
                {
                    "slug": "normal",
                    "size": "16px",
                    "name": "Normal"
                },
                {
                    "slug": "medium",
                    "size": "18px",
                    "name": "Medium"
                },
                {
                    "slug": "large",
                    "size": "24px",
                    "name": "Large"
                },
                {
                    "slug": "x-large",
                    "size": "32px",
                    "name": "Extra Large"
                }
            ]
        },
        "spacing": {
            "units": ["px", "em", "rem", "%"],
            "spacingSizes": [
                {
                    "name": "Small",
                    "slug": "small",
                    "size": "15px"
                },
                {
                    "name": "Medium",
                    "slug": "medium",
                    "size": "30px"
                },
                {
                    "name": "Large",
                    "slug": "large",
                    "size": "45px"
                }
            ]
        },
        "layout": {
            "contentSize": "1080px",
            "wideSize": "1200px"
        },
        "custom": {
            "typography": {
                "font-size": {
                    "base": "16px",
                    "scale": 1.2
                }
            },
            "spacing": {
                "unit": "1rem",
                "scale": 1.5
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--text)"
        },
        "typography": {
            "fontSize": "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.6"
        },
        "elements": {
            "h1": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--heading)",
                    "fontWeight": "700",
                    "lineHeight": "1.2"
                }
            },
            "h2": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--heading)",
                    "fontWeight": "600",
                    "lineHeight": "1.3"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--primary)"
                }
            }
        },
        "blocks": {
            "core/site-title": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--heading)",
                    "fontWeight": "700",
                    "fontSize": "24px"
                }
            },
            "core/navigation": {
                "typography": {
                    "fontSize": "16px",
                    "fontWeight": "500"
                }
            },
            "core/button": {
                "variations": {
                    "outline": {
                        "border": {
                            "width": "2px",
                            "style": "solid"
                        }
                    }
                }
            }
        }
    }
} 